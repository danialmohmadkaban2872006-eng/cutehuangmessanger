# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/cute_huang_messenger?schema=public"

# JWT — generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_here_replace_me
JWT_REFRESH_SECRET=your_refresh_secret_here_replace_me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# CORS — frontend URL
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
