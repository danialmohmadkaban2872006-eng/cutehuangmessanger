# ── Cute Huang Messenger — Frontend Environment Variables ────────────────────
# Copy this file to .env and fill in your Supabase project values.
# Find them at: https://app.supabase.com → Your Project → Settings → API

# Your Supabase project URL (format: https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase project anon/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional ─────────────────────────────────────────────────────────────────
# Set to true to enable verbose Supabase client logging during development
# VITE_SUPABASE_DEBUG=false
